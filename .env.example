TELEGRAM_BOT_TOKEN=123456:replace-me

# mild or spicy
ROAST_STYLE=spicy

# Set true if you want the bot to occasionally roast normal messages too.
ROAST_EVERY_TEXT=false
ROAST_REPLY_CHANCE=0.25

# Optional: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: enables smarter LLM roasts.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
